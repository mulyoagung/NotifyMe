{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NotifyMe Web",
  "version": "0.1.0",
  "identifier": "com.notifyme.desktop",
  "build": {
    "beforeDevCommand": "flutter build web",
    "beforeBuildCommand": "flutter build web",
    "frontendDist": "../../build/web"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "NotifyMe Web",
        "width": 1024,
        "height": 768,
        "visible": true
      },
      {
        "label": "scraper_bg",
        "title": "Background Scraper",
        "url": "https://example.com",
        "visible": false,
        "width": 800,
        "height": 600
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.ico",
      "iconAsTemplate": true
    },
    "security": {
      "csp": "default-src 'self' tauri: 'unsafe-inline' 'unsafe-eval' https: data: blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}